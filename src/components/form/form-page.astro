---
import ContactForm from './ContactForm.tsx';
---

<section id="contact" class="flex min-h-screen items-center justify-center px-4 py-16 sm:px-6 lg:px-8">
  <div class="w-full max-w-6xl grid grid-cols-1 gap-12 md:grid-cols-2">
    <!-- Lado izquierdo: Contenido -->
    <div class="flex flex-col justify-center space-y-6">
      <div>
        <h1 class="text-4xl leading-tight font-normal sm:text-5xl">
          Envia tu información y hablemos
        </h1>
      </div>

      <p class="text-base text-muted-foreground sm:text-lg">
        Tienes preguntas sobre Kiosq? Manda tu información y estaremos en contacto contigo.
      </p>
    </div>

    <!-- Lado derecho: Formulario -->
    <div class="flex flex-col justify-center">
      <ContactForm client:load />
    </div>
  </div>
</section>

<style>
  #contact {
    opacity: 1;
    animation: fadeUp 700ms ease both;
  }

  @keyframes fadeUp {
    0% {
      opacity: 0;
      transform: translateY(24px);
    }

    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #contact {
      animation: none;
    }
  }
</style>
