---
import ContactForm from './ContactForm.tsx';
---

<section id="contact" class="flex min-h-2 justify-center px-2 py-16 sm:px-6 lg:px-8">
  <div class="grid w-full max-w-6xl grid-cols-1 border border-border md:grid-cols-2">
    <header class="space-y-6 border-b border-border p-6 sm:p-8 md:border-r md:border-b-0 lg:p-12">
      <h1 class="text-balance text-4xl leading-tight font-normal sm:text-5xl">
        Envía tu información y hablemos
      </h1>

      <p class="max-w-prose text-base text-muted-foreground sm:text-lg">
        ¿Tienes preguntas sobre Kiosq? Manda tu información y estaremos en contacto contigo.
      </p>
    </header>

    <section class="p-6 sm:p-8 lg:p-12" aria-label="Formulario de contacto">
      <ContactForm client:load />
    </section>
  </div>
</section>

<style>
  #contact {
    opacity: 1;
    animation: fadeUp 700ms ease both;
  }

  @keyframes fadeUp {
    0% {
      opacity: 0;
      transform: translateY(24px);
    }

    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #contact {
      animation: none;
    }
  }
</style>
