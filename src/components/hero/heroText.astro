---
import { Button } from '@/components/ui/button';
---

<div class="space-y-8">
  <div class="space-y-6">
    <h1 class="text-balance text-5xl leading-tight font-normal sm:text-6xl">
      Gestiona tu negocio sin complicaciones
    </h1>
    <p class="text-lg text-muted-foreground sm:text-xl">
      Implementa en minutos, agiliza operaciones y aumenta la eficiencia con un POS diseñado para
      adaptarse a tu negocio.
    </p>
  </div>

  <div class="flex flex-wrap gap-4">
    <Button variant="outline" className="font-mono text-base">
      REQUEST A DEMO
    </Button>
    <Button className="font-mono text-base bg-primary text-primary-foreground hover:bg-primary/90">
      JOIN WAITLIST
    </Button>
  </div>
</div>
