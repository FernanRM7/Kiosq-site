---
import { Button } from '@/components/ui/button';
---

<div class="space-y-8 text-center">
  <div class="space-y-6">
    <h1 class="text-balance text-5xl leading-tight font-serif sm:text-6xl lg:text-7xl">
      Gestiona tu negocio sin complicaciones
    </h1>
    <p class="mx-auto max-w-3xl text-base text-foreground sm:text-lg">
      Implementa en minutos, agiliza operaciones y aumenta la eficiencia con un POS diseñado para
      adaptarse a tu negocio.
    </p>
  </div>

  <div class="flex flex-wrap justify-center gap-4">
    <Button variant="outline" className="font-mono text-base px-6">
      REQUEST A DEMO
    </Button>
    <Button className="font-mono text-base px-6 bg-blue-600 text-white hover:bg-blue-700">
      JOIN WAITLIST
    </Button>
  </div>
</div>
