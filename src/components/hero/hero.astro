---
import HeroText from './heroText.astro';
import HeroImage from './heroImage.astro';

interface Props {
  tabs?: string[];
}

const {
  tabs = ['Inventario con escaneo', 'Registro de ventas', 'Pagos', 'Proveedores']
} = Astro.props;
---

<section class="hero-shell">
  <div class="mx-auto w-full py-16">
    <!-- Hero Text Section -->
    <div class="hero-text-fade">
      <HeroText />
    </div>

    <!-- Hero Image Section -->
    <div class="hero-image-fade">
      <HeroImage tabs={tabs} />
    </div>
  </div>
</section>

<style>
  .hero-text-fade {
    animation: heroTextFade 800ms ease both;
  }

  .hero-shell {
    margin-inline: calc(var(--spacing-container) * -1);
    width: calc(100% + (var(--spacing-container) * 2));
    max-width: var(--container-width);
  }

  .hero-image-fade {
    animation: heroImageFade 800ms ease both 200ms;
  }

  @media (min-width: 40rem) {
    .hero-shell {
      margin-inline: -1.5rem;
      width: calc(100% + 3rem);
    }
  }

  @media (min-width: 64rem) {
    .hero-shell {
      margin-inline: -2rem;
      width: calc(100% + 4rem);
    }
  }

  @keyframes heroTextFade {
    0% {
      opacity: 0;
      transform: translateY(-20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroImageFade {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-text-fade,
    .hero-image-fade {
      animation: none;
    }
  }
</style>
