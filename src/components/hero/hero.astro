---
import HeroText from './heroText.astro';
import HeroImage from './heroImage.astro';

interface Props {
  imageSrc?: string;
  imageAlt?: string;
  tabs?: string[];
}

const {
  imageSrc,
  imageAlt = 'Kiosq Dashboard',
  tabs = ['Inventario con escaneo', 'Registro de ventas', 'Pagos', 'Proveedores']
} = Astro.props;
---

<section class="mx-auto w-full px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-5xl space-y-12 lg:space-y-16">
    <!-- Hero Text Section -->
    <div class="hero-text-fade">
      <HeroText />
    </div>

    <!-- Divider -->
    <div class="h-px bg-border" />

    <!-- Hero Image Section -->
    <div class="hero-image-fade">
      <HeroImage src={imageSrc} alt={imageAlt} tabs={tabs} />
    </div>
  </div>
</section>

<style>
  .hero-text-fade {
    animation: heroTextFade 800ms ease both;
  }

  .hero-image-fade {
    animation: heroImageFade 800ms ease both 200ms;
  }

  @keyframes heroTextFade {
    0% {
      opacity: 0;
      transform: translateY(-20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroImageFade {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-text-fade,
    .hero-image-fade {
      animation: none;
    }
  }
</style>
