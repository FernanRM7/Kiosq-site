---
// Footer component
---

<footer class="w-full border-t border-border bg-background">
  <div class="w-full px-4 sm:px-6">
    <!-- Main Footer Grid -->
    <div class="grid grid-cols-1 md:grid-cols-5 text-left">
      <!-- Column 1: Brand & Socials -->
      <div class="col-span-1 md:col-span-2 py-12 md:py-16 pr-0 md:pr-12 border-b md:border-b-0 md:border-r border-border flex flex-col justify-between">
        <div>
          <!-- Brand Logo and Name -->
          <div class="flex items-center gap-3 text-foreground">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="13" stroke-linejoin="round" class="size-8">
              <path d="M 50 12 L 83 31 L 83 69 L 50 88 L 17 69 L 17 31 Z"></path>
            </svg>
            <span class="font-sans font-bold text-2xl tracking-tight">Kiosq</span>
          </div>
          <!-- Brand Description -->
          <p class="mt-6 text-sm text-muted-foreground leading-relaxed max-w-sm">
            Kiosq facilita la logística de tu tienda con una interfaz sencilla de entender.
          </p>
        </div>
        <!-- Social Icons -->
        <div class="mt-8 flex items-center gap-3">
          <!-- WhatsApp Button -->
          <a
            href="https://wa.me/#"
            target="_blank"
            rel="noopener noreferrer"
            class="flex size-10 items-center justify-center rounded-xl bg-primary text-primary-foreground hover:bg-primary/95 hover:scale-105 active:scale-95 transition-all shadow-xs"
            aria-label="WhatsApp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
            </svg>
          </a>
          <!-- GitHub Button -->
          <a
            href="https://github.com/#"
            target="_blank"
            rel="noopener noreferrer"
            class="flex size-10 items-center justify-center rounded-xl bg-primary text-primary-foreground hover:bg-primary/95 hover:scale-105 active:scale-95 transition-all shadow-xs"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z"></path>
            </svg>
          </a>
          <!-- YouTube Button -->
          <a
            href="https://youtube.com/#"
            target="_blank"
            rel="noopener noreferrer"
            class="flex size-10 items-center justify-center rounded-xl bg-primary text-primary-foreground hover:bg-primary/95 hover:scale-105 active:scale-95 transition-all shadow-xs"
            aria-label="YouTube"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.518 3.5 12 3.5 12 3.5s-7.518 0-9.388.553a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11C4.482 20.5 12 20.5 12 20.5s7.518 0 9.388-.553a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Producto Links -->
      <div class="col-span-1 md:col-span-1 py-12 md:py-16 px-0 md:px-8 border-b md:border-b-0 md:border-r border-border">
        <h2 class="font-sans font-semibold text-base tracking-tight text-foreground mb-6">Producto</h2>
        <ul class="space-y-4">
          <li>
            <a href="/funcionalidades" class="text-sm text-muted-foreground hover:text-primary transition-colors">
              Funcionalidades
            </a>
          </li>
          <li>
            <a href="/precios" class="text-sm text-muted-foreground hover:text-primary transition-colors">
              Precios
            </a>
          </li>
          <li>
            <a href="/casos-de-uso" class="text-sm text-muted-foreground hover:text-primary transition-colors">
              Casos de uso
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Nosotros Links -->
      <div class="col-span-1 md:col-span-1 py-12 md:py-16 px-0 md:px-8 border-b md:border-b-0 md:border-r border-border">
        <h2 class="font-sans font-semibold text-base tracking-tight text-foreground mb-6">Nosotros</h2>
        <ul class="space-y-4">
          <li>
            <a href="/sobre-nosotros" class="text-sm text-muted-foreground hover:text-primary transition-colors">
              Sobre nosotros
            </a>
          </li>
          <li>
            <a href="/contacto" class="text-sm text-muted-foreground hover:text-primary transition-colors">
              Contacto
            </a>
          </li>
          <li>
            <a href="/lista-de-espera" class="text-sm text-muted-foreground hover:text-primary transition-colors">
              Lista de espera
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Recursos Links -->
      <div class="col-span-1 md:col-span-1 py-12 md:py-16 pl-0 md:pl-8">
        <h2 class="font-sans font-semibold text-base tracking-tight text-foreground mb-6">Recursos</h2>
        <ul class="space-y-4">
          <li>
            <a href="/terminos-de-servicio" class="text-sm text-muted-foreground hover:text-primary transition-colors">
              Términos de servicio
            </a>
          </li>
          <li>
            <a href="/politicas-de-privacidad" class="text-sm text-muted-foreground hover:text-primary transition-colors">
              Políticas de privacidad
            </a>
          </li>
          <li>
            <a href="/404" class="text-sm text-muted-foreground hover:text-primary transition-colors">
              404
            </a>
          </li>
        </ul>
      </div>
    </div>

  </div>

  <!-- Bottom Credits Bar -->
  <div class="border-t border-border w-full px-4 sm:px-6">
    <div class="py-6 flex flex-col sm:flex-row items-center justify-between text-xs text-muted-foreground gap-4">
      <p>© 2026 Kiosq</p>
      <p>Hecho en México</p>
    </div>
  </div>
</footer>
