---
import WaitlistBrand from '@/components/waitlist/waitlistBrand.astro';
import {
  waitlistFooterGroups,
  waitlistSocialLinks,
} from '@/components/waitlist/waitlistContent';

const socialShortLabel: Record<string, string> = {
  GitHub: 'GH',
  WhatsApp: 'WA',
  YouTube: 'YT',
};
---

<footer class="mx-auto w-full max-w-(--container-width) px-4 py-8 sm:px-6 lg:px-8">
  <div class="waitlist-fade-up border border-border bg-background">
    <div class="grid lg:grid-cols-[1.5fr_0.75fr_0.75fr_0.75fr]">
      <section class="space-y-8 border-b border-border p-8 lg:border-r lg:border-b-0 lg:p-10">
        <WaitlistBrand />

        <p class="max-w-[26ch] text-4xl leading-normal text-muted-foreground">
          Kiosq facilita la logística de tu tienda con una interfaz sencilla de
          entender.
        </p>

        <ul class="flex items-center gap-3">
          {
            waitlistSocialLinks.map((socialLink) => (
              <li>
                <a
                  href={socialLink.href}
                  target="_blank"
                  rel="noreferrer noopener"
                  aria-label={socialLink.label}
                  class="inline-flex size-14 items-center justify-center bg-primary font-mono text-lg uppercase tracking-widest text-primary-foreground transition-transform duration-300 hover:-translate-y-0.5 hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/60"
                >
                  <span aria-hidden="true">
                    {socialShortLabel[socialLink.label] ?? socialLink.label.slice(0, 2)}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      {
        waitlistFooterGroups.map((footerGroup) => (
          <section class="border-b border-border p-8 lg:border-r lg:border-b-0 lg:p-10 last:border-r-0">
            <h3 class="text-5xl font-semibold">{footerGroup.title}</h3>
            <ul class="mt-8 space-y-4 text-3xl text-muted-foreground">
              {footerGroup.links.map((footerLink) => (
                <li>
                  <a
                    href={footerLink.href}
                    class="transition-colors duration-300 hover:text-primary focus-visible:text-primary focus-visible:outline-none"
                  >
                    {footerLink.label}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>

  <div class="mt-4 flex flex-wrap items-center justify-between gap-3 text-2xl text-muted-foreground">
    <p>© {new Date().getFullYear()} Kiosq</p>
    <p>Hecho en México</p>
  </div>
</footer>

<style>
  .waitlist-fade-up {
    animation: waitlistFooterFade 900ms ease both;
  }

  @keyframes waitlistFooterFade {
    0% {
      opacity: 0;
      transform: translateY(24px);
    }

    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .waitlist-fade-up {
      animation: none;
    }
  }
</style>
