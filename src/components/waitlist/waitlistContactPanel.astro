<section
  id="waitlist-form"
  class="mx-auto w-full max-w-(--container-width) px-4 py-10 sm:px-6 lg:px-8"
>
  <div class="waitlist-slide-in grid border border-border bg-background lg:grid-cols-2">
    <article class="border-b border-border p-10 lg:border-r lg:border-b-0 lg:p-12">
      <h2 class="text-balance text-7xl leading-tight font-normal">
        Envía tu información y hablemos
      </h2>
      <p class="mt-8 max-w-[24ch] text-4xl leading-normal text-muted-foreground">
        Tienes preguntas sobre Kiosq? Manda tu información y estaremos en
        contacto contigo.
      </p>
    </article>

    <div class="p-10 lg:p-12">
      <form class="space-y-8" action="#waitlist-form" method="get">
        <div class="space-y-3">
          <label for="waitlist-name" class="block text-4xl font-medium">Nombre</label>
          <input
            id="waitlist-name"
            name="name"
            type="text"
            autocomplete="name"
            required
            placeholder="Jose Hernandez"
            class="h-20 w-full border border-border bg-secondary px-4 text-3xl placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-ring/40"
          />
        </div>

        <div class="space-y-3">
          <label for="waitlist-email" class="block text-4xl font-medium">Email</label>
          <input
            id="waitlist-email"
            name="email"
            type="email"
            autocomplete="email"
            required
            placeholder="example@gmail.com"
            class="h-20 w-full border border-border bg-secondary px-4 text-3xl placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-ring/40"
          />
        </div>

        <div class="space-y-3">
          <label for="waitlist-phone" class="block text-4xl font-medium">
            Número telefónico
          </label>
          <input
            id="waitlist-phone"
            name="phone"
            type="tel"
            autocomplete="tel"
            required
            placeholder="+52 234 234 8923"
            class="h-20 w-full border border-border bg-secondary px-4 text-3xl placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-ring/40"
          />
        </div>

        <div class="space-y-3">
          <label for="waitlist-help" class="block text-4xl font-medium">
            ¿Cómo podemos ayudarte en tu negocio?
          </label>
          <textarea
            id="waitlist-help"
            name="message"
            rows={4}
            required
            placeholder="Cuéntanos sobre tus metas, dificultades o qué te gustaría que esté en la aplicación."
            class="w-full border border-border bg-secondary px-4 py-4 text-3xl placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-ring/40"
          />
        </div>

        <button
          type="submit"
          class="inline-flex h-16 w-full items-center justify-center bg-primary px-6 font-mono text-3xl uppercase tracking-widest text-primary-foreground transition-transform duration-300 hover:-translate-y-0.5 hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/60"
        >
          Enviar
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .waitlist-slide-in {
    animation: waitlistSlideIn 800ms ease both;
  }

  @keyframes waitlistSlideIn {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }

    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .waitlist-slide-in {
      animation: none;
    }
  }
</style>
