---
const links = [
  { href: '#producto', label: 'Producto', hasMenu: true },
  { href: '#precios', label: 'Precios' },
  { href: '#acerca', label: 'Acerca de' },
  { href: '#recursos', label: 'Recursos', hasMenu: true },
  { href: '#waitlist', label: 'Waitlist' },
];
---

<header class="sticky top-0 z-50 py-2.5">
  <nav
    class="relative mx-auto grid h-14 max-w-7xl grid-cols-[auto_1fr_auto] items-center gap-3 rounded-lg border border-border bg-background/95 px-4 shadow-sm backdrop-blur sm:px-5 lg:h-16 lg:px-7"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="inline-flex items-center gap-2.5 text-lg font-semibold tracking-normal text-foreground"
      aria-label="Kiosq home"
    >
      <svg
        class="size-5 text-foreground"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M8.25 5.5h7.5L20 12l-4.25 6.5h-7.5L4 12l4.25-6.5Z"
          class="fill-current"
        />
        <path
          d="M8.75 10.25h6.5L14.1 14h-4.2l-1.15-3.75Z"
          class="fill-background"
        />
      </svg>
      <span>Kiosq</span>
    </a>

    <ul class="hidden items-center justify-center gap-6 lg:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="inline-flex items-center gap-1.5 text-xs font-medium text-foreground transition-colors hover:text-primary"
            >
              <span>{link.label}</span>
              {link.hasMenu && (
                <svg
                  class="size-3"
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="m4 6 4 4 4-4"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href="#waitlist"
      class="hidden h-9 items-center justify-center rounded-sm bg-primary px-4 font-mono text-xs font-medium uppercase tracking-normal text-primary-foreground transition-colors hover:bg-primary/90 lg:inline-flex"
    >
      Join waitlist
    </a>

    <details class="group justify-self-end lg:hidden">
      <summary
        class="grid size-9 cursor-pointer list-none place-items-center rounded-sm border border-border text-foreground transition-colors hover:bg-muted [&::-webkit-details-marker]:hidden"
        aria-label="Abrir menu"
      >
        <span class="sr-only">Menu</span>
        <span
          class="relative block h-0.5 w-5 rounded-full bg-current transition-transform before:absolute before:-top-1.5 before:left-0 before:h-0.5 before:w-5 before:rounded-full before:bg-current before:transition-transform after:absolute after:left-0 after:top-1.5 after:h-0.5 after:w-5 after:rounded-full after:bg-current after:transition-transform group-open:rotate-45 group-open:before:top-0 group-open:before:rotate-90 group-open:after:top-0 group-open:after:opacity-0"
          aria-hidden="true"
        >
        </span>
      </summary>

      <div
        class="absolute left-0 right-0 top-[calc(100%+0.5rem)] rounded-lg border border-border bg-background p-3 shadow-xl"
      >
        <ul class="grid gap-1">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="flex items-center justify-between px-3 py-2.5 text-sm font-medium text-foreground transition-colors hover:bg-muted"
                >
                  <span>{link.label}</span>
                  {link.hasMenu && (
                    <svg
                      class="size-3.5 text-muted-foreground"
                      viewBox="0 0 16 16"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="m4 6 4 4 4-4"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  )}
                </a>
              </li>
            ))
          }
        </ul>

        <a
          href="#waitlist"
          class="mt-3 flex h-9 items-center justify-center rounded-sm bg-primary px-4 font-mono text-xs font-medium uppercase tracking-normal text-primary-foreground transition-colors hover:bg-primary/90"
        >
          Join waitlist
        </a>
      </div>
    </details>
  </nav>
</header>
