// use prisma-next

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String?
  name      String?
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt temporal.updatedAt()
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  author    User     @relation(fields: [authorId], references: [id])
  authorId  Int
  createdAt DateTime @default(now())
  updatedAt temporal.updatedAt()
}

model ContactForm {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt temporal.updatedAt()

  @@index([email])
  @@index([createdAt])
}

model Waitlist {
  id        Int      @id @default(autoincrement())
  email     String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt temporal.updatedAt()

  @@index([email])
  @@index([createdAt])
}
